      },
      {
        "type": "horizontal-barchart",
        "content": {
          "title": "Reasons for leaving",
          "bars": [
            { "label": "Lack of career growth", "value": 34 },
            { "label": "Compensation", "value": 22 },
            { "label": "Management issues", "value": 19 },
            { "label": "Work-life balance", "value": 14 }
          ]
        }
      },
      {
        "type": "text",
        "content": {
          "text": "Junior employees under 2 years show 2.4x higher attrition. Consider implementing structured career reviews at the 12-month mark."
        }
      }
    ]
